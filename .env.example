# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️ ÖNEMLİ GÜVENLİK UYARISI ⚠️
# ═══════════════════════════════════════════════════════════════════════════════
# Bu dosyayı GİTHUB'A YÜKLEMEYİN!
# API anahtarlarınızı ve şifrelerinizi içerir.
# Render.com'daki Environment Variables bölümüne tek tek ekleyin.
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# TELEGRAM BOT AYARLARI
# ═══════════════════════════════════════════════════════════════════════════════
# BotFather'dan aldığınız Telegram Bot token'ı
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ═══════════════════════════════════════════════════════════════════════════════
# GROQ API AYARLARI (ÜCRETSİZ LLM)
# ═══════════════════════════════════════════════════════════════════════════════
# Groq API anahtarınız (https://console.groq.com - ÜCRETSİZ)
GROQ_API_KEY=your_groq_api_key_here

# Kullanılacak model (llama-3.1-70b-versatile en güçlü ücretsiz model)
GROQ_MODEL=llama-3.1-70b-versatile

# ═══════════════════════════════════════════════════════════════════════════════
# PEXELS API AYARLARI (ÜCRETSİZ)
# ═══════════════════════════════════════════════════════════════════════════════
# Pexels'tan alacağınız API anahtarı (https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# İNSTAGRAM AYARLARI
# ═══════════════════════════════════════════════════════════════════════════════
# İnstagrapi için Instagram hesap bilgileri
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ═══════════════════════════════════════════════════════════════════════════════
# İÇERİK AYARLARI
# ═══════════════════════════════════════════════════════════════════════════════
# Takip edilecek RSS feed URL'leri
RSS_FEEDS=https://www.theverge.com/rss/index.xml,https://feeds.feedburner.com/TechCrunch/

# Takip edilecek Reddit subreddit'leri
REDDIT_SUBREDDITS=technology,programming,artificial

# Botun odaklanacağı içerik kategorisi
CONTENT_NICHE=technology

# Otomatik içerik kontrol aralığı (dakika cinsinden)
CONTENT_CHECK_INTERVAL=60

# ═══════════════════════════════════════════════════════════════════════════════
# VİDEO AYARLARI
# ═══════════════════════════════════════════════════════════════════════════════
# Video boyutları (Instagram Reels için 9:16 aspect ratio)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# Video kalitesi (1080, 720, 480)
VIDEO_QUALITY=1080

# Video saniye başına kare (FPS)
VIDEO_FPS=30

# Seslendirme dili (tr, en, es, fr, de, vb.) - TÜRKÇE İÇİN: tr
TTS_LANGUAGE=tr

# Video önizleme ayarı (True = video oluşturulduktan sonra size gönderilir)
SEND_PREVIEW=True

# Manuel onay modu (True = paylaşım için sizin onayınız gerekir)
MANUAL_APPROVAL=True

# ═══════════════════════════════════════════════════════════════════════════════
# ZAMANLAMA AYARLARI
# ═══════════════════════════════════════════════════════════════════════════════
# En iyi paylaşım saatleri (Türkiye için UTC+3)
BEST_POST_TIMES=09:00,12:30,19:00,21:00

# ═══════════════════════════════════════════════════════════════════════════════
# LOGLAMA AYARLARI
# ═══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
LOG_TO_CONSOLE=True
LOG_TO_FILE=True

# ═══════════════════════════════════════════════════════════════════════════════
# DİĞER AYARLAR
# ═══════════════════════════════════════════════════════════════════════════════
MAX_TOKENS=2048
